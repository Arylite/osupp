{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "ci-debug",
      "displayName": "CI Debug (warnings are errors)",
      "inherits": "debug",
      "cacheVariables": { "OSUPP_WERROR": "ON" }
    },
    {
      "name": "ci-release",
      "displayName": "CI Release (warnings are errors)",
      "inherits": "release",
      "cacheVariables": { "OSUPP_WERROR": "ON" }
    },
    {
      "name": "vs2022",
      "displayName": "Visual Studio 2022",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/vs2022",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "debug" },
    { "name": "release", "configurePreset": "release" },
    { "name": "ci-debug", "configurePreset": "ci-debug" },
    { "name": "ci-release", "configurePreset": "ci-release" }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ci-debug",
      "configurePreset": "ci-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ci-release",
      "configurePreset": "ci-release",
      "output": { "outputOnFailure": true }
    }
  ]
}
